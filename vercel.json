{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/(app|today|library|review|year|roidboy)$", "dest": "/index.html" },
    { "src": "^(.*)$", "dest": "/index.html" }
  ]
}
